RewriteEngine on
RewriteCond %{HTTP_HOST} ^sorteios.videiraaraguari.com.br$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www.sorteios.videiraaraguari.com.br$
RewriteCond %{REQUEST_URI} !public/
RewriteRule (.*) /public/$1 [L]

